# Auto-detect text files and normalize line endings to LF
* text=auto

# Shell scripts should always use LF line endings
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
